<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Jed\Component\Jed\Site\Field">
    <fieldset>
        <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
        <field name="internal" type="checkbox" default="0" label="COM_TICKETS_TICKETMESSAGE_INTERNAL_LABEL"
               description="COM_TICKETS_TICKETMESSAGE_INTERNAL_DESCR"
               hint="COM_TICKETS_TICKETMESSAGE_INTERNAL_LABEL"/>
        <field name="subject" filter="safehtml" type="text" required="true" message="Please enter a subject"
               label="COM_TICKETS_GENERAL_SUBJECT_LABEL" description="COM_TICKETS_FORM_DESC_TICKETMESSAGE_SUBJECT"
               hint="COM_TICKETS_GENERAL_SUBJECT_LABEL"/>
        <field name="message" editor="jce|codemirror||" buttons="false" filter="JComponentHelper::filterText"
               type="editor" required="true" message="Please enter a message"
               label="COM_TICKETS_EXTENSION_MESSAGE_LABEL" description="COM_TICKETS_FORM_DESC_TICKETMESSAGE_MESSAGE"
               hint="COM_TICKETS_EXTENSION_MESSAGE_LABEL"/>
        <field name="ticket_id" type="foreignkey" label="COM_TICKETS_TICKETMESSAGE_TICKET_ID_LABEL"
               description="COM_TICKETS_TICKETS_TICKET_ID_DESCR" input_type="list" table="#__jed_tickets"
               key_field="id" value_field="ticket_subject" default="0"/>
        <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL"
               description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label"/>
    </fieldset>
</form>
