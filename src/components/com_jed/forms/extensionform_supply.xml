<?xml version="1.0" encoding="utf-8"?>
<form enctype="multipart/form-data" method="post">
    <fieldset>
        <field name="supply_option_id" type="foreignkey" required="true"
               label="COM_JED_EXTENSION_SUPPLY_OPTION_LABEL"
               input_type="list"
               table="#__jed_extension_supply_options"
               key_field="id"
               value_field="title" />

        <field name="is_default_data" type="radio" class="btn-group btn-group-yesno" default="0"
               label="COM_JED_EXTENSION_IS_DEFAULT_DATA_LABEL">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>

        <field name="title" type="text" filter="safehtml" label="JGLOBAL_TITLE" />

        <field name="description" type="textarea" filter="safehtml"
               label="COM_JED_EXTENSION_DESCRIPTION_LABEL" />

        <field name="homepage_link" type="url" validate="url" label="COM_JED_EXTENSION_HOMEPAGE_LINK_LABEL" />
        <field name="download_link" type="url" validate="url" label="COM_JED_EXTENSION_DOWNLOAD_LINK_LABEL" />
        <field name="demo_link" type="url" validate="url" label="REMOVE_COM_JED_EXTENSION_DEMO_LINK_LABEL" />
        <field name="support_link" type="url" validate="url" label="COM_JED_GENERAL_SUPPORT_LABEL" />
        <field name="documentation_link" type="url" validate="url" label="COM_JED_EXTENSION_DOCUMENTATION_LABEL" />
        <field name="license_link" type="url" validate="url" label="COM_JED_EXTENSION_LICENSE_LINK_LABEL" />
        <field name="translation_link" type="url" validate="url" label="REMOVECOM_JED_FORM_LBL_EXTENSIONVARIEDDATUM_TRANSLATION_LINK" />

        <field name="download_integration_type" type="list"
               label="COM_JED_EXTENSION_DOWNLOAD_INTEGRATION_TYPE_LABEL"
               description="COM_JED_EXTENSION_DOWNLOAD_INTEGRATION_TYPE_DESCR"
               default="1">
            <option value="0">COM_JED_EXTENSION_DOWNLOAD_INTEGRATION_TYPE_OPTION_0</option>
            <option value="1">COM_JED_EXTENSION_DOWNLOAD_INTEGRATION_TYPE_OPTION_1</option>
            <option value="2">COM_JED_EXTENSION_DOWNLOAD_INTEGRATION_TYPE_OPTION_2</option>
            <option value="3">COM_JED_EXTENSION_DOWNLOAD_INTEGRATION_TYPE_OPTION_3</option>
        </field>

        <field name="download_integration_url" type="url" validate="url"
               label="COM_JED_EXTENSION_DOWNLOAD_INTEGRATION_URL_LABEL"
               description="COM_JED_EXTENSION_DOWNLOAD_INTEGRATION_URL_DESCR"
               showon="download_integration_type:1,2,3" />
    </fieldset>
</form>