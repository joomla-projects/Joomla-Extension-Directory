<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Jed\Component\Jed\Site\Field">
    <fieldset name="common" label="COM_JED_FIELDSET_COMMON_LABEL">
        <field name="id" type="hidden" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
        <field name="name" filter="safehtml" type="text" label="JGLOBAL_TITLE" required="true"
               hint="COM_JED_GENERAL_TITLE_LABEL"/>
        <field name="alias" type="text" class="inputbox" generator="title" label="JFIELD_ALIAS_LABEL" hint="JALIAS"/>
        <field name="catid" extension="com_jed" type="category" published="1" multiple="false" required="true"
               label="COM_JED_GENERAL_CATEGORY_ID_LABEL"
               hint="COM_JED_GENERAL_CATEGORY_ID_LABEL"/>
        <field name="categories" extension="com_jed" type="category" published="1" multiple="true"
               label="COM_JED_EXTENSION_CATEGORIES_LABEL"
               hint="COM_JED_EXTENSION_CATEGORIES_LABEL"/>
        <field name="owner" type="hidden" readonly="true" filter="unset"/>
    </fieldset>

    <fieldset name="info" label="COM_JED_FIELDSET_INFO_LABEL">
        <field name="intro" editor="tinymce" buttons="false" filter="Joomla\CMS\Component\ComponentHelper::filterText"
               type="editor" label="COM_JED_EXTENSION_INTRO_TEXT_LABEL"
               hint="COM_JED_EXTENSION_INTRO_TEXT_LABEL"/>
        <field name="description" editor="tinymce" buttons="false" filter="Joomla\CMS\Component\ComponentHelper::filterText"
               type="editor" label="COM_JED_EXTENSION_DESCRIPTION_LABEL"
               hint="COM_JED_EXTENSION_DESCRIPTION_LABEL"/>
        <field name="license" filter="safehtml" type="text" label="COM_JED_EXTENSION_LICENSE_LABEL"
               hint="COM_JED_EXTENSION_LICENSE_LABEL"/>
        <field
                name="requires_registration"
                type="radio"
                label="COM_JED_EXTENSION_REQUIRES_REGISTRATION_LABEL"
                class="btn-group btn-group-yesno"
                default="0"
                filter="integer"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="type" type="list" default="free" label="COM_JED_GENERAL_TYPE_LABEL">
            <option value="free">COM_JED_GENERAL_TYPE_LABEL_FREE</option>
            <option value="paid">COM_JED_GENERAL_TYPE_LABEL_PAID</option>
            <option value="freemium">COM_JED_GENERAL_TYPE_LABEL_FREEMIUM</option>
            <option value="cloud">COM_JED_GENERAL_TYPE_LABEL_CLOUD</option>
        </field>
        <field
                name="extension_types"
                type="checkboxes"
                label="COM_JED_EXTENSION_EXTENSION_TYPE_LABEL"
        >
            <option value="com">COM_JED_EXTENSION_COMPONENT_LABEL</option>
            <option value="mod">COM_JED_EXTENSION_MODULE_LABEL</option>
            <option value="plugin">COM_JED_EXTENSION_PLUGIN_LABEL</option>
            <option value="specific">COM_JED_EXTENSION_SPECIFIC_LABEL</option>
        </field>
        <field
                name="joomla_versions"
                type="checkboxes"
                label="COM_JED_EXTENSION_JOOMLA_VERSIONS_LABEL"
        >
            <option value="30">3.0</option>
            <option value="40">4.0</option>
            <option value="41">4.1</option>
            <option value="42">4.2</option>
            <option value="43">4.3</option>
            <option value="44">4.4</option>
            <option value="50">5.0</option>
            <option value="60">6.0</option>
        </field>
    </fieldset>

    <fieldset name="links" label="COM_JED_FIELDSET_LINKS_LABEL">
        <field name="download_url" validate="url" type="url" label="COM_JED_EXTENSION_DOWNLOAD_LINK_LABEL"
               hint="COM_JED_EXTENSION_DOWNLOAD_LINK_LABEL"/>
        <field name="support_url" validate="url" type="url" label="COM_JED_EXTENSION_SUPPORT_LINK_LABEL"
               hint="COM_JED_EXTENSION_SUPPORT_LINK_LABEL"/>
        <field name="demo_url" validate="url" type="url" label="COM_JED_EXTENSION_DEMO_LINK_LABEL"
               hint="COM_JED_EXTENSION_DEMO_LINK_LABEL"/>
        <field name="documentation_url" validate="url" type="url"
               label="COM_JED_EXTENSION_DOCUMENTATION_LINK_LABEL"
               hint="COM_JED_EXTENSION_DOCUMENTATION_LINK_LABEL"/>
        <field name="git_url" validate="url" type="url" label="COM_JED_EXTENSION_GIT_URL_LABEL"
               hint="COM_JED_EXTENSION_GIT_URL_LABEL"/>
        <field name="internal_download_url" validate="url" type="url"
               label="COM_JED_EXTENSION_INTERNAL_DOWNLOAD_URL_LABEL"
               hint="COM_JED_EXTENSION_INTERNAL_DOWNLOAD_URL_LABEL"/>
        <field name="download_key" filter="safehtml" type="text" label="COM_JED_EXTENSION_DOWNLOAD_KEY_LABEL"
               hint="COM_JED_EXTENSION_DOWNLOAD_KEY_LABEL"/>
        <field name="uses_updater" default="0" type="radio" class="btn-group btn-group-yesno"
               label="COM_JED_EXTENSION_USES_UPDATER_LABEL">
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>
        <field name="update_url" validate="url" type="url" label="COM_JED_EXTENSION_UPDATE_URL_LABEL"
               hint="COM_JED_EXTENSION_UPDATE_URL_LABEL"/>
        <field name="developer_url" validate="url" type="url" label="COM_JED_EXTENSION_DEVELOPER_URL_LABEL"
               hint="COM_JED_EXTENSION_DEVELOPER_URL_LABEL"/>
        <field name="developer_email" filter="string" type="email" label="COM_JED_EXTENSION_DEVELOPER_EMAIL_LABEL"
               hint="COM_JED_EXTENSION_DEVELOPER_EMAIL_LABEL"/>
        <field name="changelog_url" validate="url" type="url" label="COM_JED_EXTENSION_CHANGELOG_URL_LABEL"
               hint="COM_JED_EXTENSION_CHANGELOG_URL_LABEL"/>
    </fieldset>

    <fieldset name="media" label="COM_JED_FIELDSET_MEDIA_LABEL">
        <field
                name="logo"
                type="media"
                label="COM_JED_EXTENSION_LOGO_LABEL"
                class="input-xxlarge"
                preview="true"
                directory=""
        />
        <field
                name="overview_image"
                type="media"
                label="COM_JED_EXTENSION_OVERVIEW_IMAGE_LABEL"
                class="input-xxlarge"
                preview="true"
                directory=""
        />
        <field name="video" type="url" class="span12" label="COM_JED_EXTENSION_VIDEO_LABEL"/>

        <field name="images"
               type="subform"
               multiple="true"
               max="100"
               layout="joomla.form.field.subform.repeatable"
               label="COM_JED_EXTENSION_IMAGES_LABEL"
               buttons="add,remove"
        >
            <form>
                <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
                <field name="filename" type="file" accept="image/*" class="jed-upload-input"
                       label="COM_JED_EXTENSIONIMAGE_FILENAME_LABEL"
                       hint="COM_JED_EXTENSIONIMAGE_FILENAME_LABEL"/>
                <field name="state" default="1" type="list" label="JSTATUS" description="JFIELD_PUBLISHED_DESC"
                       class="inputbox" size="1">
                    <option value="1">JPUBLISHED</option>
                    <option value="0">JUNPUBLISHED</option>
                    <option value="2">JARCHIVED</option>
                    <option value="-2">JTRASHED</option>
                </field>
                <field name="ordering"/>
                <field name="checked_out" type="hidden" filter="unset"/>
                <field name="checked_out_time" type="hidden" filter="unset"/>
                <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL"
                       hidden="true"/>
                <field name="modified_by" type="modifiedby" default="0" label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
                       hidden="true"/>
            </form>
        </field>
    </fieldset>

    <fieldset name="maintainers" label="COM_JED_FIELDSET_MAINTAINERS_LABEL">
        <field name="maintainer"
               type="subform"
               multiple="true"
               max="50"
               layout="joomla.form.field.subform.repeatable"
               label="COM_JED_EXTENSION_MAINTAINERS_LABEL"
               buttons="add,remove"
        >
            <form>
                <field name="user_id" type="user" label="JGLOBAL_FIELD_USER_LABEL" required="true"/>
            </form>
        </field>
    </fieldset>

    <fieldset name="files" label="COM_JED_FIELDSET_FILES_LABEL">
        <field name="files"
               type="subform"
               multiple="true"
               max="20"
               layout="joomla.form.field.subform.repeatable"
               label="COM_JED_EXTENSION_FILES_LABEL"
               buttons="add,remove"
        >
            <form>
                <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
                <field name="file" type="file" class="jed-upload-input" label="COM_JED_EXTENSIONFILE_FILE_LABEL"
                       hint="COM_JED_EXTENSIONFILE_FILE_LABEL"/>
                <field name="originalFile" type="text" readonly="true" label="COM_JED_EXTENSIONFILE_ORIGINALFILE_LABEL"
                       hint="COM_JED_EXTENSIONFILE_ORIGINALFILE_LABEL"/>
                <field name="meta" type="hidden" filter="raw"/>
                <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL"
                       hidden="true"/>
            </form>
        </field>
    </fieldset>

    <fieldset name="publishing" label="JGLOBAL_FIELDSET_PUBLISHING">
        <field name="created_by" type="hidden" readonly="true" filter="unset"/>
        <field name="created" type="hidden" readonly="true" filter="unset"/>
        <field name="modified_by" type="hidden" readonly="true" filter="unset"/>
        <field name="modified" type="hidden" readonly="true" filter="unset"/>
        <field name="checked_out" type="hidden" filter="unset"/>
        <field name="checked_out_time" type="hidden" filter="unset"/>
    </fieldset>
</form>
